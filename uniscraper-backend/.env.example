OPENROUTER_API_KEY=your_openrouter_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
MONGODB_URI=mongodb+srv://username:password%40host@cluster.mongodb.net/
DB_NAME=autonova_scraper
MAX_SUBPAGES=20
MAX_DEPTH=4
MAX_CONCURRENT_FETCHES=8
MIN_PAGE_WORDS=30
MAX_PDFS=2

# OpenRouter Free Model Chain (July 2026 - VERIFIED WORKING IDs)
# Extraction Priority (ai_extractor.py):
#   1. meta-llama/llama-3.3-70b-instruct:free      (stable, verified working)
#   2. nvidia/nemotron-3-super-120b-a12b:free      (large context, complex reasoning)
#   3. openai/gpt-oss-120b:free                    (strong JSON formatting)
#   4. qwen/qwen3-next-80b-a3b-instruct:free       (fast inference, if available)
#
# Enrichment Priority (ai_enrichment.py):
#   1. meta-llama/llama-3.3-70b-instruct:free      (stable, best for structured data)
#   2. nvidia/nemotron-3-super-120b-a12b:free      (complex reasoning)
#   3. openai/gpt-oss-120b:free                    (JSON cleanup)
#   4. qwen/qwen3-next-80b-a3b-instruct:free       (fast, if available)
#
# Auto-fallback chain implemented — if primary model fails/rate-limits,
# automatically tries next model in priority list.
#
# Context compression: Automatically reduces large contexts (>20k chars) to <15k
# for free models to avoid 400 Bad Request errors.
#
# IMPORTANT: Free tier limits (as of July 2026):
#   - 50 requests/day (no credits added)
#   - 1,000 requests/day (with $10+ lifetime credits)
#   For production scraping, $10 top-up recommended.
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
LLM_MAX_TOKENS=4000
LLM_CONTEXT_LIMIT=50000
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"
LOG_LEVEL=INFO

# Three-tier fetching pipeline
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
CRAWL4AI_ENABLED=true
FIRECRAWL_ENABLED=true

# Phase 2: Program discovery

# Jina AI Search (primary discovery engine)
# Get free API key (10M tokens) at: https://jina.ai/reader
# Searches domain + Gemini picks best catalog URL
JINA_API_KEY=your_jina_api_key_here

# SearXNG (unlimited search, recommended - set up local instance or use public)
# Local: docker run -d --name searxng -p 8080:8080 searxng/searxng
# Then set: SEARXNG_URL=http://localhost:8080
# Public fallback: SEARXNG_URL=https://search.inetol.net
SEARXNG_URL=

# Paid search APIs (fallback if SearXNG unavailable)
SERPAPI_KEY=your_serpapi_key_here
SERPAPI_ENABLED=true
SEARCHAPI_KEY=your_searchapi_key_here
SEARCHAPI_ENABLED=true

# Client-approved scope: 30-50 graduate programs per university (midpoint=40)
MAX_PROGRAMS_PER_UNIVERSITY=40

# Google Vertex AI (recommended by reviewers - higher quotas and reliability)
# Step 1: Get service account JSON from your company/reviewers
# Step 2: Place it in: uniscraper-backend/credentials/vertex-key.json
# Step 3: Set VERTEX_PROJECT_ID to your GCP project ID
# Step 4: Set VERTEX_ENABLED=true to activate
VERTEX_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=C:\Projects\uniscrape\uniscraper-backend\credentials\vertex-key.json
VERTEX_ENABLED=false
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.0-flash-exp

# Jina AI Search (for program discovery - web search + content fetching)
# Get free API key at: https://jina.ai/reader
JINA_API_KEY=your_jina_api_key_here
